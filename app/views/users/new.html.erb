<div class="card shadow-sm col-md-6 mx-auto">
  <div class="card-header bg-white">
    <h4>Novo Usuário</h4>
  </div>

  <div class="card-body">

    <%= form_with(model: @user, url: users_path, local: true) do |f| %>

      <div class="mb-3">
        <%= f.label :username, "Usuário", class: "form-label" %>
        <%= f.text_field :username, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "Confirmar Senha", class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-control" %>
      </div>

      <div class="d-flex justify-content-end">
        <%= f.submit "Salvar Usuário", class: "btn btn-primary" %>
      </div>

    <% end %>

  </div>
</div>