<!DOCTYPE html>
<html>
  <head>
    <title>CadastroVeiculos</title>

    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <!-- Bootstrap 5 -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
  </head>

  <body class="bg-light">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
      <div class="container">

        <button id="darkModeBtn" class="btn btn-dark btn-sm">
          🌙
        </button>

<div class="position-relative">

  <button class="btn btn-outline-light btn-sm">
    🔔
  </button>

  <% if @total_veiculos > 0 %>
    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
      <%= @total_veiculos %>
    </span>
  <% end %>

</div>

        <%= link_to "🚗 Cadastro de Veículos",
            root_path,
            class: "navbar-brand fw-bold" %>

        <div class="ms-auto d-flex align-items-center gap-2">

          <% if user_signed_in? %>

  <span class="text-white me-2">
    👤 <%= current_user.username %>
  </span>

  <%= link_to "Veículos", veiculos_path, class: "btn btn-outline-light btn-sm" %>

  <%= link_to "Novo Veículo", new_veiculo_path, class: "btn btn-success btn-sm" %>

  <%= button_to "Sair",
      destroy_user_session_path,
      method: :delete,
      class: "btn btn-danger btn-sm" %>

<% end %>

        </div>
      </div>
    </nav>

    <!-- CONTEÚDO -->
    <div class="container mt-4">

      <% if notice %>
        <div class="alert alert-success text-center">
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>

    </div>

    <!-- FOOTER -->
<footer class="text-center mt-5 text-muted">
  <hr>
  Sistema de Cadastro de Veículos © 2026
</footer>

<script>
document.addEventListener("DOMContentLoaded", function() {

  const btn = document.getElementById("darkModeBtn");

  // verifica se o modo escuro já estava ativado
  if (localStorage.getItem("darkMode") === "enabled") {
    document.body.classList.add("bg-dark", "text-white");
  }

  if (btn) {
    btn.addEventListener("click", function() {

      document.body.classList.toggle("bg-dark");
      document.body.classList.toggle("text-white");

      // salva estado
      if (document.body.classList.contains("bg-dark")) {
        localStorage.setItem("darkMode", "enabled");
      } else {
        localStorage.setItem("darkMode", "disabled");
      }

    });
  }

});
</script>

</body>
</html>