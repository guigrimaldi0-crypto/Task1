<div class="card shadow-sm">

  <div class="card-header bg-light d-flex justify-content-between align-items-center">
    <h4 class="mb-0">Lista de Veículos</h4>
    <%= link_to "🚗 Novo Veículo", new_veiculo_path, class: "btn btn-success btn-sm" %>
  </div>

  <div class="card-body">

    <div class="card mb-3 shadow-sm text-center">
      <div class="card-body">
        <h5>Total de veículos cadastrados</h5>
        <h2 class="text-primary">🚗 <%= @total_veiculos %></h2>
      </div>
    </div>

    <%= search_form_for @q do |f| %>

      <div class="row mb-3">

        <div class="col-md-6">
          <%= f.search_field :modelo_or_marca_or_placa_cont,
              placeholder: "Buscar por modelo, marca ou placa...",
              class: "form-control" %>
        </div>

        <div class="col-md-2">
          <%= f.label :ano_eq, "Ano" %>
          <%= f.number_field :ano_eq, class: "form-control" %>
        </div>

        <div class="col-md-2">
          <%= f.label :marca_cont, "Marca" %>
          <%= f.search_field :marca_cont, class: "form-control" %>
        </div>

        <div class="col-md-2 d-flex align-items-end">
          <%= f.submit "Filtrar", class: "btn btn-primary w-100" %>
        </div>

      </div>

    <% end %>

    <table class="table table-striped">

      <thead>
        <tr>
          <th>Modelo</th>
          <th>Marca</th>
          <th>Ano</th>
          <th>Placa</th>
          <th>Ações</th>
        </tr>
      </thead>

      <tbody>

        <% @veiculos.each do |veiculo| %>
          <tr>

            <td><%= veiculo.modelo %></td>
            <td><%= veiculo.marca %></td>
            <td><%= veiculo.ano %></td>
            <td><%= veiculo.placa %></td>

            <td>
              <%= link_to "Editar",
                  edit_veiculo_path(veiculo),
                  class: "btn btn-warning btn-sm" %>

              <%= button_to "Excluir",
                  veiculo_path(veiculo),
                  method: :delete,
                  data: { turbo_confirm: "Deseja realmente excluir este veículo?" },
                  class: "btn btn-danger btn-sm" %>
            </td>

          </tr>
        <% end %>

      </tbody>

    </table>

    <div class="mt-3 d-flex justify-content-center">
      <%== pagy_bootstrap_nav(@pagy) %>
    </div>

  </div>

</div>